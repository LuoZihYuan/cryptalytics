# Copy this file to `secrets.yaml` (gitignored) and fill in real values
# before running `kubectl apply -k infrastructure/kubernetes/overlays/local`.
apiVersion: v1
kind: Secret
metadata:
  name: ingestion-secrets
  namespace: cryptalytics
type: Opaque
stringData:
  INGESTION_AIRFLOW_USERNAME: ""
  INGESTION_AIRFLOW_PASSWORD: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: tick-processor-secrets
  namespace: cryptalytics
type: Opaque
stringData:
  TICK_PROCESSOR_S3_ACCESS_KEY: ""
  TICK_PROCESSOR_S3_SECRET_KEY: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secrets
  namespace: cryptalytics
type: Opaque
stringData:
  mongodb-root-password: ""